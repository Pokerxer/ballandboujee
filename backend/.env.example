# Medusa Backend Environment Variables
# Kentaz E-commerce Platform

# Database Configuration
DATABASE_URL=postgres://postgres:postgres@localhost:5432/medusa_kentaz
DATABASE_LOGGING=true

# Redis Configuration (required for Medusa)
REDIS_URL=redis://localhost:6379

# Application Settings
NODE_ENV=development
PORT=9000
ADMIN_PORT=7000

# Session & Security
SESSION_SECRET=your-super-secret-session-token-change-in-production
JWT_SECRET=your-super-secret-jwt-token-change-in-production
COOKIE_SECRET=your-super-secret-cookie-token-change-in-production

# CORS Configuration
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:7000

# Email Configuration
EMAIL_FROM=noreply@kentaz.com
# For production, configure SMTP settings
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-email-password

# Payment Provider - Paystack
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret

# File Storage
FILE_KEY=local-file-key-change-in-production

# Feature Flags
FEATURE_STOCK_RESERVATION=false

# Logging
LOG_LEVEL=debug

# Optional: Algolia Search
# ALGOLIA_APP_ID=your-algolia-app-id
# ALGOLIA_ADMIN_KEY=your-algolia-admin-key
# ALGOLIA_SEARCH_KEY=your-algolia-search-key

# Optional: Sentry Error Tracking
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# Optional: SMS Notifications (Twilio)
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_FROM_NUMBER=+1234567890
